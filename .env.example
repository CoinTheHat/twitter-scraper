# Twitter Account Credentials
# Get these from your browser cookies when logged into twitter.com/x.com
# (DevTools → Application → Cookies → auth_token and ct0)

# Option 1: Single account
TWITTER_AUTH_TOKEN=your_auth_token_here
TWITTER_CT0=your_ct0_here

# Option 2: Multiple accounts (comma-separated)
# TWITTER_AUTH_TOKENS=token1,token2,token3
# TWITTER_CT0S=ct0_1,ct0_2,ct0_3

# Option 3: Numbered env vars
# TWITTER_AUTH_TOKEN_1=token1
# TWITTER_CT0_1=ct0_1
# TWITTER_AUTH_TOKEN_2=token2
# TWITTER_CT0_2=ct0_2

# Optional: Proxies (one per account, comma-separated)
# TWITTER_PROXIES=http://proxy1:8080,http://proxy2:8080

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info
